# Copy to .env.local and fill in values. Do not commit secrets.

# --- PostgreSQL (API routes + NextAuth adapter) ---
DATABASE_HOST=localhost
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_NAME=refresh
# Set to "true" if your provider requires TLS (e.g. cloud Postgres)
# DATABASE_SSL=false

# --- Google Generative AI (server: scan, suggest-cuisines, etc.) ---
GEMINI_API_KEY=
# Optional: override default model (default is gemini-3-flash-preview in lib/gemini-model.ts)
# GEMINI_MODEL=gemini-3-flash-preview
# GEMINI_VISION_MODEL=

# --- Google Generative AI (client: cuisine chatbot in browser) ---
# Exposed to the client; use a restricted key when possible.
NEXT_PUBLIC_GEMINI_API_KEY=
# NEXT_PUBLIC_GEMINI_MODEL=gemini-3-flash-preview

# --- NextAuth v5 (Google sign-in) ---
# Generate: openssl rand -base64 32
AUTH_SECRET=
# App URL, e.g. http://localhost:3000 or https://your-domain.com
AUTH_URL=http://localhost:3000
# Often needed behind proxies / Vercel
# AUTH_TRUST_HOST=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
